{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "rootDir": "src",
    "outDir": "dist/web/js",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/ui/**/*.ts",
    "src/core/**/*.ts"
  ],
  "exclude": [
    "dist/web/js",
    "node_modules"
  ]
}
